{
  "name": "yuque-session",
  "version": "0.1.0",
  "description": "语雀 CLI + MCP 工具 - 基于 Session Cookie 认证，无需会员",
  "type": "module",
  "bin": {
    "yuque": "./dist/cli/index.js"
  },
  "main": "dist/mcp/server.js",
  "files": [
    "dist"
  ],
  "scripts": {
